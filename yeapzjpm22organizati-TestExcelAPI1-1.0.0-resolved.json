{
  "swagger": "2.0",
  "info": {
    "description": "A test API to simulate Excel import endpoints for K2",
    "version": "1.0.0",
    "title": "Test Excel API1"
  },
  "host": "virtserver.swaggerhub.com",
  "basePath": "/yeapzjpm22organizati/TestExcelAPI1/1.0.0",
  "schemes": [
    "https"
  ],
  "paths": {
    "/todos/{id}": {
      "get": {
        "summary": "Get a single todo item",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID of the todo item",
            "required": true,
            "type": "integer"
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "schema": {
              "$ref": "#/definitions/inline_response_200"
            }
          }
        }
      }
    },
    "/excel/import": {
      "post": {
        "summary": "Simulate Excel import",
        "consumes": [
          "application/json"
        ],
        "parameters": [
          {
            "in": "body",
            "name": "excelData",
            "description": "JSON data representing Excel rows",
            "required": true,
            "schema": {
              "type": "array",
              "items": {
                "$ref": "#/definitions/excelData"
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Import successful",
            "schema": {
              "$ref": "#/definitions/inline_response_200_1"
            }
          }
        }
      }
    }
  },
  "definitions": {
    "excelData": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "example": "John Doe"
        },
        "age": {
          "type": "integer",
          "example": 25
        },
        "email": {
          "type": "string",
          "example": "john@example.com"
        }
      }
    },
    "inline_response_200_1": {
      "type": "object",
      "properties": {
        "status": {
          "type": "string",
          "example": "success"
        },
        "insertedRows": {
          "type": "integer",
          "example": 3
        }
      }
    },
    "inline_response_200": {
      "type": "object",
      "properties": {
        "userId": {
          "type": "integer",
          "example": 1
        },
        "id": {
          "type": "integer",
          "example": 1
        },
        "title": {
          "type": "string",
          "example": "delectus aut autem"
        },
        "completed": {
          "type": "boolean",
          "example": false
        }
      }
    }
  }
}